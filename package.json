{
  "name": "echoes",
  "version": "1.2.1",
  "description": "ECHO desktop application",
  "main": "./out/main/index.js",
  "author": "Moekotori",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext js,jsx,cjs,mjs,ts,tsx --fix",
    "test:unit": "node --test test/unit/*.test.mjs",
    "verify:release": "node scripts/verify-release.mjs",
    "postinstall": "cross-env PYTHONUTF8=1 electron-builder install-app-deps",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "rebuild:native": "cross-env PYTHONUTF8=1 electron-builder install-app-deps",
    "build": "electron-vite build",
    "build:win": "electron-vite build && node scripts/build-win.mjs",
    "build:win:release": "electron-vite build && electron-builder --win -c.directories.output=release",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "theme:audit": "node scripts/theme-audit.mjs --write",
    "build:audio-host": "node scripts/build-audio-host.mjs"
  },
  "build": {
    "appId": "com.echoes.studio",
    "productName": "ECHO",
    "icon": "website/icon.png",
    "publish": [
      {
        "provider": "github",
        "owner": "Moekotori",
        "repo": "Echoes"
      }
    ],
    "directories": {
      "output": "dist",
      "buildResources": "electron-app/build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "NCMconverter.exe",
        "to": "NCMconverter.exe"
      },
      {
        "from": "electron-app/build",
        "to": ".",
        "filter": [
          "echo-audio-host",
          "echo-audio-host.exe"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "website/icon.png",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "npmRebuild": false,
    "asarUnpack": [
      "**/node_modules/kuromoji/**",
      "**/node_modules/ffmpeg-static/**",
      "**/node_modules/naudiodon/**"
    ]
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@neteasecloudmusicapienhanced/api": "^4.31.0",
    "axios": "^1.13.6",
    "color-thief-react": "^2.1.0",
    "discord-rpc": "^4.0.1",
    "dompurify": "^3.4.0",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "html2canvas": "^1.4.1",
    "i18next": "^26.0.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "jsmediatags": "^3.9.5",
    "kuromoji": "^0.1.2",
    "kuroshiro": "^1.2.0",
    "kuroshiro-analyzer-kuromoji": "^1.1.0",
    "lucide-react": "^0.475.0",
    "marked": "^18.0.0",
    "music-metadata": "^11.12.3",
    "naudiodon": "^2.3.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.1",
    "react-youtube": "^10.1.0",
    "youtube-dl-exec": "^3.1.4"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^2.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^10.1.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.4",
    "prettier": "^3.4.2",
    "vite": "^5.4.14"
  }
}
