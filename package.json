{
  "name": "echoes",
  "version": "1.0.0",
  "description": "Echoes Desktop Application",
  "main": "./out/main/index.js",
  "author": "Antigravity",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext js,jsx,cjs,mjs,ts,tsx --fix",
    "postinstall": "cross-env PYTHONUTF8=1 electron-builder install-app-deps",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "rebuild:native": "cross-env PYTHONUTF8=1 electron-builder install-app-deps",
    "build": "electron-vite build",
    "build:win": "electron-vite build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "build": {
    "appId": "com.echoes.studio",
    "productName": "Echoes Studio",
    "directories": {
      "output": "dist",
      "buildResources": "electron-app/build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "NCMconverter.exe",
        "to": "NCMconverter.exe"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "electron-app/build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "npmRebuild": false,
    "asarUnpack": [
      "**/node_modules/kuromoji/**"
    ]
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@neteasecloudmusicapienhanced/api": "^4.31.0",
    "axios": "^1.13.6",
    "discord-rpc": "^4.0.1",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "jsmediatags": "^3.9.5",
    "kuromoji": "^0.1.2",
    "kuroshiro": "^1.2.0",
    "kuroshiro-analyzer-kuromoji": "^1.1.0",
    "lucide-react": "^0.475.0",
    "music-metadata": "^11.12.3",
    "naudiodon": "^2.3.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-youtube": "^10.1.0",
    "youtube-dl-exec": "^3.1.4"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^2.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^10.1.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.4",
    "prettier": "^3.4.2",
    "vite": "^5.4.14"
  }
}
